# AI provider: "ollama" (local) or "1min" (1min.ai cloud)
AI_PROVIDER=ollama

# Required only when AI_PROVIDER=1min
ONE_MIN_API_KEY=your_1min_api_key_here

# ── Enrichment API keys ──────────────────────────────────────────────────────
# AbuseIPDB  → https://www.abuseipdb.com/account/api  (free: 1,000 checks/day)
ABUSEIPDB_API_KEY=your_abuseipdb_key_here

# AlienVault OTX → https://otx.alienvault.com/api  (free with account)
OTX_API_KEY=your_otx_key_here

# VirusTotal → https://www.virustotal.com/gui/my-apikey  (free: 4 req/min, 500/day)
VIRUSTOTAL_API_KEY=your_virustotal_key_here

# GreyNoise  → https://viz.greynoise.io/account/  (community tier available)
GREYNOISE_API_KEY=your_greynoise_key_here

# Shodan     → https://account.shodan.io/  (paid; limited free tier)
SHODAN_API_KEY=your_shodan_key_here

# URLhaus, WHOIS, and ASN require no API key.

# ── Infrastructure ───────────────────────────────────────────────────────────
# URL of the SentinelForge API (used by the Streamlit dashboard)
SENTINELFORGE_API_URL=http://127.0.0.1:8001

# SQLite database file path (default: data/sentinelforge.db)
# To switch to Postgres: postgresql+psycopg2://user:pass@host/dbname
DATABASE_URL=sqlite:///data/sentinelforge.db

# Logging level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
